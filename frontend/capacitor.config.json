{
  "appId": "com.academe.app",
  "appName": "Academe",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "plugins": {
    "PushNotifications": {
      "presentationOptions": [
        "badge",
        "sound",
        "alert"
      ]
    },
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0ea5e9"
    }
  },
  "android": {
    "allowMixedContent": true
  },
  "ios": {
    "contentInset": "automatic"
  },
  "server": {
    "androidScheme": "https"
  }
}
