/**
 * ADDING CUSTOM COMPONENTS
 * 
 * The theme system is designed to be extensible. To add custom elements:
 * 
 * 1. Create a new component that receives isDark prop
 * 2. Inside component, destructure theme:
 *    const theme = isDark ? ACADEME_THEME.dark : ACADEME_THEME.light;
 * 3. Apply theme colors:
 *    color={theme.primary}
 *    emissive={theme.secondary}
 * 4. Follow opacity guidelines for consistency
 * 
 * Example:
 * 
 * function CustomGlow({ isDark }) {
 *     const theme = isDark ? ACADEME_THEME.dark : ACADEME_THEME.light;
 *     return (
 *         <mesh>
 *             <sphereGeometry args={[1, 32, 32]} />
 *             <meshStandardMaterial
 *                 color={theme.primary}
 *                 emissive={theme.secondary}
 *                 emissiveIntensity={isDark ? 0.5 : 0.2}
 *             />
 *         </mesh>
 *     );
 * }
 */

